#!/usr/bin/env python3
"""
damascus_laundry dashboard launcher.

Usage:  ./damascus_laundry_dashboard [--port N]

Starts a tiny HTTP server that serves the dashboard HTML and proxies
JSON reads to wallet.json + wallet.cycles.jsonl on every poll.

Action buttons (Start/Stop/Seed/Mode) call shell out to the existing
scripts/.
"""
import argparse
import http.server
