from typing import Optional
from urllib.parse import urlparse

REPO = Path(__file__).resolve().parent
WALLET = REPO / "wallet.json"
CYCLES = REPO / "wallet.cycles.jsonl"
PID = REPO / "trader.pid"
LOG = REPO / "trader.log"
SCRIPTS = REPO / "scripts"

# v2.0 live-mode operator console (DAM-72). The dashboard reads the
# JSON that dl-app writes atomically at 1 Hz from `dl-app::live_status`
# (DAM-82). Path is the same as the writer's default: `./live_status.json`
# in the launcher's repo. Never raises — a missing file is a normal
# paper-mode startup condition, the dashboard renders OFFLINE.
LIVE_STATUS = REPO / "live_status.json"


def _read_live_status():
    """Read live_status.json. Returns (dict, status_str). status_str
    is one of: 'ok', 'missing', 'malformed'. Never raises."""
    if not LIVE_STATUS.exists():
        return None, "missing"
    try:
        with LIVE_STATUS.open() as f:
            data = json.load(f)
        if not isinstance(data, dict):
            return None, "malformed"
        return data, "ok"
    except (OSError, ValueError):
        return None, "malformed"

# Submission-to-landing latency probe. The probe sends real
# sendTransaction + getSignatureStatuses calls every probe_interval_s
# and times the round-trip — the network leg of submit-to-confirm,
# which is what determines MEV win rate. Set DL_PROBE_ENABLED=0 to
# disable.
from latency_probe import LatencyProbe, _read_endpoint_from_env, _wss_to_https

_LATENCY_PROBE: Optional[LatencyProbe] = None
_LAST_PROBE_TICK_MS = 0
_PROBE_INTERVAL_MS = 4000  # 4s probe cadence; the probe itself is ~700ms
_LATENCY_HISTORY: list[int] = []  # legacy fallback cache (unused)


def _ensure_probe() -> Optional[LatencyProbe]:
    global _LATENCY_PROBE
    if _LATENCY_PROBE is not None:
        return _LATENCY_PROBE
    enabled = os.environ.get("DL_PROBE_ENABLED", "1") != "0"
    if not enabled:
        return None
    wss = _read_endpoint_from_env(REPO / ".env")
    if not wss:
        return None
    https_url = _wss_to_https(wss)
    interval_s = float(os.environ.get("DL_PROBE_INTERVAL_S", "4"))
    _LATENCY_PROBE = LatencyProbe(
        rpc_url=https_url,
        interval_s=interval_s,
        enabled=True,
    )
    return _LATENCY_PROBE


def _maybe_tick_probe() -> None:
    """Run a probe at most once per _PROBE_INTERVAL_MS. No-op if disabled."""
    global _LAST_PROBE_TICK_MS
    probe = _ensure_probe()
    if probe is None:
        return
    now_ms = int(time.time() * 1000)
    if now_ms - _LAST_PROBE_TICK_MS < _PROBE_INTERVAL_MS:
        return
    _LAST_PROBE_TICK_MS = now_ms
    probe.tick(force=False)


def sol_usd():
    try:
        out = subprocess.check_output(
            ["curl", "-sf", "--max-time", "3",
             "https://api.coinbase.com/v2/prices/SOL-USD/spot"],
            stderr=subprocess.DEVNULL, timeout=3,
        )
        return float(json.loads(out)["data"]["amount"])
    except Exception:
        return None


def lamports_to_sol(l):
    return l / 1_000_000_000


def read_wallet():
    if not WALLET.exists():
        return None
    try:
        with WALLET.open() as f:
            return json.load(f)
    except Exception:
        return None


def read_log_tail(n=80):
    if not LOG.exists():
        return []
    try:
        with LOG.open("rb") as f:
            try:
                f.seek(0, 2)
                size = f.tell()
                f.seek(max(0, size - 32_000), 0)
                lines = f.read().decode(errors="replace").splitlines()
            except Exception:
                lines = LOG.read_text(errors="replace").splitlines()
        return lines[-n:]
    except Exception:
        return []


def is_running():
    if not PID.exists():
        return False
    try:
        pid = int(PID.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, OSError):
        return False


def api_snapshot():
    w = read_wallet() or {}
    bal = int(w.get("balance_lamports", 0))
    start = int(w.get("starting_balance_lamports", 0))
    trades = w.get("trades", []) or []
    wins = sum(1 for t in trades if t.get("profit_lamports", 0) > 0)
    losses = len(trades) - wins
    pnl = bal - start
    pxs = sol_usd()
    _maybe_tick_probe()
    snap = _LATENCY_PROBE.snapshot() if _LATENCY_PROBE else {"endpoint": "(unset)", "latency_ms": None}
    return {
        "running": is_running(),
        "wallet": w,
        "balance_lamports": bal,
        "balance_sol": lamports_to_sol(bal),
        "starting_lamports": start,
        "pnl_lamports": pnl,
        "pnl_sol": lamports_to_sol(pnl),
        "sol_usd": pxs,
        "balance_usd": (lamports_to_sol(bal) * pxs) if pxs else None,
        "pnl_usd": (lamports_to_sol(pnl) * pxs) if pxs else None,
        "trades_total": len(trades),
        "wins": wins,
        "losses": losses,
        "win_rate": (wins / len(trades) * 100.0) if trades else 0.0,
        "log_tail": read_log_tail(60),
        "rpc": snap,
        "ts": int(time.time() * 1000),
    }


def api_live_snapshot():
    """Build the /api/live payload for the v2.0 operator console (DAM-72).

    Reads ./live_status.json (REPO / live_status.json) which dl-app writes
    at 1 Hz per DAM-82 contract v1. Returns a shape dashboard/live.html
    already understands:

        {
          ok: bool,                     # false → render the OFFLINE banner
          reason: str,                  # human-readable reason when !ok
          ts: int,                      # ms epoch; when the snapshot was built
          running: bool,                # bot is running
          daily_cap_lamports: int,
          daily_spent_lamports: int,
          daily_spent_pct: float,       # 0..100
          kill_switch: {open, stop_file_present,
                        consecutive_losses, max_consecutive_losses, reason},
          last_landed_bundle_id: str|null,
          last_landed_at_unix_ms: int|null,
          last_landed_profit_lamports: int|null,
          realized_pnl_today_lamports: int,
          realized_pnl_today_sol: float,
          realized_pnl_today_usd: float|null,
          sol_usd: float|null,
          sol_usd_source: str,          # 'pyth' | 'coinbase-fallback' | 'none'
          sol_usd_age_secs: int|null,
          contract: {schema_version, ts_unix_ms, fields_present: [str],
                     fields_missing: [str]},
        }

    Never raises. States handled (see DAM-82 acceptance):
      - 'missing'   — no file: ok=false, reason='live_status missing'
      - 'malformed' — bad JSON / not a dict: ok=false, reason='live_status malformed'
      - 'mismatch'  — wrong schema_version: ok=false, reason='schema_mismatch:N'
      - 'valid'     — all 11 contract fields present
      - 'valid_partial' — at least one field present, some missing
    """
    raw, live_state = _read_live_status()
    now_ms = int(time.time() * 1000)
    if raw is None:
        # Missing or malformed at the JSON layer. Render the OFFLINE
        # banner (Domain Lens #5: blank screen is a bug). The HTML
        # falls back to a '—' render for every field.
        return {
            "ok": False,
            "reason": "live_status " + live_state,  # 'missing' or 'malformed'
            "ts": now_ms,
            "running": False,
            "daily_cap_lamports": 0,
            "daily_spent_lamports": 0,
            "daily_spent_pct": 0.0,
            "kill_switch": {
                "open": False,
                "stop_file_present": False,
                "consecutive_losses": None,
                "max_consecutive_losses": None,
                "reason": None,
            },
            "last_landed_bundle_id": None,
            "last_landed_at_unix_ms": None,
            "last_landed_profit_lamports": None,
            "realized_pnl_today_lamports": 0,
            "realized_pnl_today_sol": 0.0,
            "realized_pnl_today_usd": None,
            "sol_usd": None,
            "sol_usd_source": "none",
            "sol_usd_age_secs": None,
            "contract": {
                "schema_version": None,
                "ts_unix_ms": None,
                "fields_present": [],
                "fields_missing": ["(file " + live_state + ")"],
            },
        }

    # Schema-version check. DAM-82 says v1 is the contract; if the bot
    # starts emitting v2 we don't silently mis-render — the dashboard
    # shows the OFFLINE banner with a reason that names the version
    # it saw, so the operator notices and we bump the consumer.
    sv = raw.get("schema_version")
    if sv != 1:
        return {
            "ok": False,
            "reason": "schema_mismatch:" + str(sv),
            "ts": now_ms,
            "running": False,
            "daily_cap_lamports": 0,
            "daily_spent_lamports": 0,
            "daily_spent_pct": 0.0,
            "kill_switch": {
                "open": False,
                "stop_file_present": False,
                "consecutive_losses": None,
                "max_consecutive_losses": None,
                "reason": None,
            },
            "last_landed_bundle_id": None,
            "last_landed_at_unix_ms": None,
            "last_landed_profit_lamports": None,
            "realized_pnl_today_lamports": 0,
            "realized_pnl_today_sol": 0.0,
            "realized_pnl_today_usd": None,
            "sol_usd": None,
            "sol_usd_source": "none",
            "sol_usd_age_secs": None,
            "contract": {
                "schema_version": sv,
                "ts_unix_ms": raw.get("ts_unix_ms"),
                "fields_present": [],
                "fields_missing": ["(schema_mismatch)"],
            },
        }

    # Track field presence so the operator can spot a partial contract
    # at a glance (e.g. DAM-42 leaves sol_usd null). The JS ignores
    # this — it's a debugging affordance, available in the JSON.
    expected_fields = [
        "ts_unix_ms", "running", "daily_cap_lamports", "daily_spent_lamports",
        "kill_switch", "last_landed_bundle", "realized_pnl_today_lamports",
        "sol_usd", "sol_usd_source", "sol_usd_age_secs",
    ]
    fields_present = [f for f in expected_fields if f in raw]
    fields_missing = [f for f in expected_fields if f not in raw]

    cap = int(raw.get("daily_cap_lamports", 0) or 0)
    spent = int(raw.get("daily_spent_lamports", 0) or 0)
    spent_pct = (spent / cap * 100.0) if cap > 0 else 0.0
    ks = raw.get("kill_switch") or {}
    llb = raw.get("last_landed_bundle") or {}
    pnl_lamports = int(raw.get("realized_pnl_today_lamports", 0) or 0)
    pnl_sol = lamports_to_sol(pnl_lamports)
    sol_usd_src = raw.get("sol_usd_source") or "none"
    # Frontend never calls a price API directly (it would race the bot's
    # own Pyth feed and the operator would see two different numbers).
    # We use the value dl-app publishes; the launcher does not
    # backfill with Coinbase. If the field is null, render '—'.
    sol_usd_val = raw.get("sol_usd")
    sol_usd_age = raw.get("sol_usd_age_secs")
    pnl_usd = (pnl_sol * float(sol_usd_val)) if sol_usd_val else None
    ts_unix_ms = int(raw.get("ts_unix_ms", now_ms) or now_ms)
    return {
        "ok": True,
        "reason": "ok",
        "ts": ts_unix_ms,
        "running": bool(raw.get("running", False)),
        "daily_cap_lamports": cap,
        "daily_spent_lamports": spent,
        "daily_spent_pct": round(spent_pct, 4),
        "kill_switch": {
            "open": bool(ks.get("open", False)),
            "stop_file_present": bool(ks.get("stop_file_present", False)),
            "consecutive_losses": ks.get("consecutive_losses"),
            "max_consecutive_losses": ks.get("max_consecutive_losses"),
            "reason": ks.get("reason"),
        },
        "last_landed_bundle_id": llb.get("bundle_id"),
        "last_landed_at_unix_ms": llb.get("ts_unix_ms"),
        "last_landed_profit_lamports": llb.get("profit_lamports"),
        "realized_pnl_today_lamports": pnl_lamports,
        "realized_pnl_today_sol": pnl_sol,
        "realized_pnl_today_usd": pnl_usd,
        "sol_usd": sol_usd_val,
        "sol_usd_source": sol_usd_src,
        "sol_usd_age_secs": sol_usd_age,
        "contract": {
            "schema_version": sv,
            "ts_unix_ms": ts_unix_ms,
            "fields_present": fields_present,
            "fields_missing": fields_missing,
        },
    }


def run_script(name, *args):
    p = SCRIPTS / name
    if not p.exists():
        return {"ok": False, "error": f"script not found: {p}"}
    try:
        out = subprocess.check_output(
            [str(p), *args], stderr=subprocess.STDOUT, timeout=10
        )
        return {"ok": True, "output": out.decode(errors="replace")}
    except subprocess.CalledProcessError as e:
        return {"ok": False, "error": e.output.decode(errors="replace")}
    except Exception as e:
        return {"ok": False, "error": str(e)}


def read_env():
    env_path = REPO / ".env"
    if not env_path.exists():
        return {}
    out = {}
    for line in env_path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        k, _, v = line.partition("=")
        out[k.strip()] = v.strip().strip('"').strip("'")
    return out


def write_env_mode(mode):
    env_path = REPO / ".env"
    if not env_path.exists():
        return False
    lines = env_path.read_text().splitlines()
    out = []
    seen = False
    for line in lines:
        if line.startswith("DL_PAPER_MODE="):
            out.append(f"DL_PAPER_MODE={mode}")
            seen = True
        else:
            out.append(line)
    if not seen:
        out.append(f"DL_PAPER_MODE={mode}")
    env_path.write_text("\n".join(out) + "\n")
    return True


class ReusableTCPServer(http.server.ThreadingHTTPServer):
    """Bind with SO_REUSEADDR so the server can rebind immediately
    after Ctrl-C (which leaves the port in TIME_WAIT for ~60s)."""
    allow_reuse_address = True
    allow_reuse_port = True


class Handler(http.server.BaseHTTPRequestHandler):
    def log_message(self, *args, **kw):
        pass

    def _send_json(self, obj, status=200):
        body = json.dumps(obj).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def _send_html(self, body):
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        path = urlparse(self.path).path
        if path == "/" or path == "/index.html":
            html = (REPO / "dashboard" / "index.html").read_bytes()
            self._send_html(html)
        elif path == "/api/snapshot":
            self._send_json(api_snapshot())
        elif path == "/api/cycles":
            data = []
            if CYCLES.exists():
                for line in CYCLES.read_text().splitlines()[-200:]:
                    try:
                        data.append(json.loads(line))
                    except Exception:
                        pass
            self._send_json({"cycles": data, "count": len(data)})
        elif path == "/api/env":
            env = read_env()
            self._send_json({
                "DL_LIVE_MODE": env.get("DL_LIVE_MODE", "unset"),
                "DL_PAPER_MODE": env.get("DL_PAPER_MODE", "optimistic"),
                "DL_LIVE_WS_URL": env.get("DL_LIVE_WS_URL", ""),
                "DL_LIVE_POOL_PUBKEYS": env.get("DL_LIVE_POOL_PUBKEYS", ""),
                "DL_LIVE_DURATION_SECS": env.get("DL_LIVE_DURATION_SECS", "3600"),
            })
        elif path == "/api/live":
            # v2.0 live-mode operator console (DAM-72). Source:
            # ./live_status.json written by dl-app per DAM-82 contract v1.
            # Returns ok=false (not 5xx) when the file is missing,
            # malformed, or schema_mismatch — the dashboard JS renders
            # the OFFLINE banner in that case.
            self._send_json(api_live_snapshot())
        elif path == "/live" or path == "/live.html":
            # v2.0 live-mode operator console page (DAM-72).
            # Sibling to "/" → "dashboard/index.html".
            live_html = REPO / "dashboard" / "live.html"
            if not live_html.exists():
                self.send_error(404)
                return
            self._send_html(live_html.read_bytes())
        else:
            self.send_error(404)

    def do_POST(self):
        path = urlparse(self.path).path
        length = int(self.headers.get("Content-Length", "0") or "0")
        raw = self.rfile.read(length) if length else b"{}"
        try:
            body = json.loads(raw.decode() or "{}")
        except Exception:
            body = {}
        if path == "/api/start":
            self._send_json(run_script("start_paper_trader.sh"))
        elif path == "/api/stop":
            self._send_json(run_script("stop_paper_trader.sh"))
        elif path == "/api/seed":
            sol = float(body.get("sol", 1.0))
            self._send_json(run_script("seed_wallet.sh", f"{sol}"))
        elif path == "/api/mode":
            mode = body.get("mode", "optimistic")
            if mode not in ("optimistic", "realistic"):
                self._send_json({"ok": False, "error": "invalid mode"}, 400)
                return
            ok = write_env_mode(mode)
            self._send_json({"ok": ok, "mode": mode})
        elif path == "/api/refresh":
            self._send_json(api_snapshot())
        elif path == "/api/probe":
            enabled = bool(body.get("enabled", True))
            if _LATENCY_PROBE is not None:
                _LATENCY_PROBE.enabled = enabled
            self._send_json({"ok": True, "enabled": enabled})
        else:
            self.send_error(404)


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--port", type=int, default=8765)
    ap.add_argument("--host", default="127.0.0.1")
    args = ap.parse_args()
    server = ReusableTCPServer((args.host, args.port), Handler)
    url = f"http://{args.host}:{args.port}/"
    print(f"damascus_laundry dashboard: {url}")
    print("Press Ctrl-C to stop.")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nstopped.")


if __name__ == "__main__":
    main()
