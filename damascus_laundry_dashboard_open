#!/usr/bin/env bash
# Launch the damascus_laundry dashboard in your browser.
# Usage:  ./damascus_laundry_dashboard_open [--no-browser] [--port N]
#         (then Ctrl-C to stop the server)
#
# The server is `exec`'d in this shell so SIGINT (Ctrl-C) goes
# directly to the server, not to a wrapper that has to forward
# it. One process, one PID, one Ctrl-C.
set -euo pipefail
REPO="$(cd "$(dirname "$0")" && pwd)"
PORT="${DL_DASHBOARD_PORT:-8765}"
OPEN_BROWSER=1
while [[ $# -gt 0 ]]; do
    case "$1" in
        --no-browser) OPEN_BROWSER=0; shift ;;
        --port) PORT="${2:-8765}"; shift 2 ;;
        --kill-orphans) KILL_ORPHANS=1; shift ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

# Kill any orphaned dashboard servers from previous Ctrl-C or kill
# invocations. Look for our exact binary path, not just "python3"
# (which would also kill the user's other Python processes).
if command -v pgrep >/dev/null 2>&1; then
    ORPHANS=$(pgrep -f "damascus_laundry_dashboard --port" 2>/dev/null || true)
    if [[ -n "${ORPHANS:-}" ]]; then
        echo "killing orphan dashboard processes: $ORPHANS"
        # shellcheck disable=SC2086
        kill -TERM $ORPHANS 2>/dev/null || true
        sleep 0.5
        # If still alive, force-kill
        ORPHANS2=$(pgrep -f "damascus_laundry_dashboard --port" 2>/dev/null || true)
        if [[ -n "${ORPHANS2:-}" ]]; then
            # shellcheck disable=SC2086
            kill -KILL $ORPHANS2 2>/dev/null || true
        fi
    fi
fi
# Also free the port if anything else is holding it
if command -v fuser >/dev/null 2>&1; then
    fuser -k "${PORT}/tcp" 2>/dev/null || true
fi

# Pre-launch the browser on the first request. We do this in
# parallel with the server starting so the user sees the page
# as soon as the server is ready.
URL="http://127.0.0.1:${PORT}/"
if [[ $OPEN_BROWSER -eq 1 ]]; then
    (
        # Poll the server up to 5s for readiness, then open the browser
        for i in $(seq 1 50); do
            if curl -sf --max-time 1 "$URL" >/dev/null 2>&1; then
                if command -v xdg-open >/dev/null 2>&1; then xdg-open "$URL" >/dev/null 2>&1 || true
                elif command -v open >/dev/null 2>&1; then open "$URL" >/dev/null 2>&1 || true
                elif command -v firefox >/dev/null 2>&1; then firefox "$URL" >/dev/null 2>&1 &
                elif command -v google-chrome >/dev/null 2>&1; then google-chrome "$URL" >/dev/null 2>&1 &
                fi
                exit 0
            fi
            sleep 0.1
        done
    ) &
fi

# exec replaces the shell process with the server, so SIGINT
# from Ctrl-C is delivered directly to python — no wrapper to
# forward, no second process to clean up. The PID we print is
# the server's PID; killing it stops the server.
echo "damascus_laundry dashboard: $URL"
echo "Press Ctrl-C to stop."
exec python3 "${REPO}/damascus_laundry_dashboard" --port "$PORT" --host 127.0.0.1
