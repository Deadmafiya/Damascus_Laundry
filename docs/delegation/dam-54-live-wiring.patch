+/// DAM-54a: prune edges from the streaming detector's graph whose
+/// source pool is older than `max_pool_age_slots` slots at
+/// `now_slot`. Called by the live trading path on every
+/// `FeedEvent::Slot` so the price graph tracks real-time pool
+/// freshness instead of accumulating edges from pools that have
+/// gone silent.
+///
+/// `pools` is the **current** pool universe tracked by the live
+/// trading pipeline (the `raydium_pools` / `orca_pools` /
+/// `meteora_pools` maps in `run_live_paper` snapshotted via
+/// `snapshot_all_pools`). Each pool's `last_update_slot` is the
+/// baseline for the staleness check.
+///
+/// `max_pool_age_slots == 0` short-circuits to a no-op (matches
+/// `dl_feed::staleness` cold-start default).
+///
+/// Returns the [`PruneReport`] from `dl_detect::staleness` so the
+/// caller can log drop counts. The process-wide
+/// `STALE_EDGES_PRUNED_TOTAL` counter is bumped by the underlying
+/// `prune_stale_edges` call.
+pub fn handle_slot_event(
+    detector: &mut dl_stream::detector::StreamingDetector,
+    pools: &[dl_state::pool::Pool],
+    now_slot: u64,
+    max_pool_age_slots: u64,
+) -> dl_detect::staleness::PruneReport {
+    detector
+        .graph_mut()
+        .prune_stale_edges(pools, now_slot, max_pool_age_slots)
+}
