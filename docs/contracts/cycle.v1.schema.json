{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://damascus.local/contracts/cycle.v1.schema.json",
  "title": "cycle.v1",
  "description": "Wire contract for a single detected cycle emitted by dl-app and ingested by dl-pipeline. See docs/contracts/cycle.v1.md.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "cycle_id",
    "detected_at_unix_ms",
    "detected_at_slot",
    "bot_run_id",
    "dexes",
    "legs",
    "base_mint",
    "quote_mint",
    "gross_bps",
    "fee_bps_sum",
    "decision",
    "evaluator",
    "input_lamports",
    "output_lamports",
    "source_feed"
  ],
  "properties": {
    "schema": { "const": "cycle.v1" },
    "cycle_id": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "detected_at_unix_ms": { "type": "integer", "minimum": 0 },
    "detected_at_slot": { "type": "integer", "minimum": 0 },
    "bot_run_id": { "type": "string", "format": "uuid" },
    "dexes": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["raydium", "orca", "meteora"] }
    },
    "legs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pool", "dex", "direction", "weight"],
        "properties": {
          "pool": { "type": "string", "minLength": 32, "maxLength": 64 },
          "dex": { "enum": ["raydium", "orca", "meteora"] },
          "direction": { "enum": ["BaseToQuote", "QuoteToBase"] },
          "weight": { "type": "integer" }
        }
      }
    },
    "base_mint": { "type": "string" },
    "quote_mint": { "type": "string" },
    "gross_bps": { "type": "integer" },
    "fee_bps_sum": { "type": "integer", "minimum": 0 },
    "decision": { "enum": ["WouldTrade", "WouldNotTrade"] },
    "evaluator": { "enum": ["conservative_default", "optimistic"] },
    "input_lamports": { "type": "integer", "minimum": 0 },
    "output_lamports": { "type": "integer", "minimum": 0 },
    "source_feed": { "enum": ["ws:mainnet", "ws:devnet", "capture:replay"] }
  }
}
