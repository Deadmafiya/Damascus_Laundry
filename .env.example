#!/usr/bin/env bash
# damascus_laundry paper trader — single source of truth for env vars.
# Copy to .env, fill in your real values, run ../scripts/start_paper_trader.sh

# Live mode: devnet | mainnet-paper | mainnet
# (refused by default; must explicitly opt in)
DL_LIVE_MODE=mainnet

# WebSocket RPC URL (free tier: QuickNode, Helius, Triton, etc.)
# Required for --feed live. QuickNode example:
DL_LIVE_WS_URL=

# Comma-separated known mainnet pool addresses to subscribe to via
# accountSubscribe. Public mainnet pool addresses are free.
# Default: 3 SOL/USDC pools across Raydium/Orca/Meteora (the minimum
# needed to find multi-DEX cycles). Add more for richer graph coverage.
DL_LIVE_POOL_PUBKEYS=58oQChx4yWmvKdwLLZzBi4ChoCc2fqCUWBkwMihLYQo2,Czfq3xZZDmsdGdUyrNLtRhGc47cXcZtLG4crryfu44zE,HTvjzsfX3yU6BUodCjZ5vZkUrAxMDTrBs3CJaq43ashR

# How long the bot runs in seconds (default 3600 = 1 hour).
# For overnight runs: 28800 (8h) or 86400 (24h).
DL_LIVE_DURATION_SECS=28800
